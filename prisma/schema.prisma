// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model Student {
  docs String[]@map("documents")//make separate route named "upload-student-docs"
  studentCard String? @map("student_card")//make separate route named "upload-student-card"
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  //for database column rename use @map
  rollNo       Int          @map("roll_no")
  CreatedAt    DateTime     @default(now()) @map("created_at")
  UpdatedAt    DateTime     @default(now()) @map("updated_at")
  departmentId Int          @map("department_id") //foreign key to Department
  department   Department   @relation(fields: [departmentId], references: [id]) //Belongs to one department
  enrollments  Enrollment[]

  //for custom table name use @@map
  @@map("students")
}

model Department {
  id        Int       @id @default(autoincrement())
  CreatedAt DateTime  @default(now()) @map("created_at")
  UpdatedAt DateTime  @updatedAt @map("updated_at")
  name      String    @unique
  teachers  Teacher[] //one department has amny teachers
  students  Student[]

  @@map("departments")
}

model Teacher {
  id           Int        @id @default(autoincrement())
  CreatedAt    DateTime   @default(now()) @map("created_at")
  UpdatedAt    DateTime   @updatedAt @map("updated_at")
  name         String     @unique
  // email        String     @unique
  departmentId Int        @map("department_id") //foreign key to Department
  department   Department @relation(fields: [departmentId], references: [id]) //Belongs to one department

  courses Course[] //one teacher can teach multiple courses

  @@map("teachers")
}

model Course {
  id          Int          @id @default(autoincrement())
  CreatedAt   DateTime     @default(now()) @map("created_at")
  UpdatedAt   DateTime     @default(now()) @map("updated_at")
  name        String
  credit      Int
  teacher_id  Int          @map("teacher_id")
  teacher     Teacher      @relation(fields: [teacher_id], references: [id]) //belongs to one teacher
  enrollments Enrollment[]

  @@map("courses")
}

model Enrollment {
  id         Int      @id @default(autoincrement())
  CreatedAt  DateTime @default(now()) @map("created_at")
  UpdatedAt  DateTime @updatedAt @map("updated_at")
  student_id Int      @map("student_id")
  student    Student  @relation(fields: [student_id], references: [id])
  course_id  Int      @map("course_id")
  course     Course   @relation(fields: [course_id], references: [id])
  enrolledAt DateTime @default(now()) @map("enrollment_at")
  status     String   @default("Active")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String //store hashed password,never store the plain text password
  role      String   @default("user") //can be "user" or "admin"
  profileImage String? @map("profile_image")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
